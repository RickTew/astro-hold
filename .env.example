# Copy this file to `.env.local` (gitignored, Vite auto-loads it) for local
# dev, and add the same two vars to the Vercel project so production builds
# get them (Vercel > AstroHold > Settings > Environment Variables).
#
# Both values are PUBLIC: the URL is the hub endpoint and the publishable
# key is meant to ship in the client bundle. RLS (deny-by-default, keyed on
# auth.uid()) is what actually protects player rows - not key secrecy.
#
# The client is scoped to the `astro_hold` schema, so it can only ever see
# AstroHold's own tables, never the sibling games living in `public`.
VITE_SUPABASE_URL=https://guwquufbifuzmphcdsdt.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_Gsb1b9FVsphHfEqZVQBrFw_3f5rxOuk
